# Environment Configuration

# Midnight Network
MIDNIGHT_RPC_URL=https://testnet-rpc.midnight.network
MIDNIGHT_CONTRACT_ADDRESS=0x1234567890abcdef
MIDNIGHT_CHAIN_ID=testnet

# Lace Wallet
LACE_WALLET_API_KEY=your_api_key_here
LACE_WALLET_SECRET=your_secret_here

# Oracle Service
ORACLE_ENABLED=true
ORACLE_MEMBERS=oracle-1,oracle-2,oracle-3

# Frontend
REACT_APP_CONTRACT_ADDRESS=0x1234567890abcdef
REACT_APP_RPC_URL=https://testnet-rpc.midnight.network
REACT_APP_API_URL=http://localhost:3001

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
CREDIPRO_ENCRYPTION_KEY=change-me-32-characters-min!!

# Database (SQLite — file created at runtime by backend)
DATABASE_PATH=./credipro.sqlite

# Logging
LOG_LEVEL=info