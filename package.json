{
  "name": "credipro-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Privacy-preserving decentralized lending on Midnight Network",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build -w backend",
    "build:frontend": "npm run build -w credipro-frontend",
    "dev": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w credipro-frontend",
    "dev:all": "npm run dev -w backend & npm run dev -w credipro-frontend",
    "test": "npm run test -w backend",
    "test:watch": "npm run test:watch -w backend",
    "test:coverage": "npm run test:coverage -w backend",
    "test:integration": "npm run test:integration -w backend",
    "lint": "npm run lint -w backend",
    "format": "npm run format -w backend",
    "compile:contract": "npm run compile:contract -w backend",
    "start:backend": "npm run dev -w backend",
    "start:frontend": "npm run dev -w credipro-frontend",
    "audit": "npm audit -ws"
  },
  "author": "Credipro Team",
  "license": "MIT",
  "overrides": {
    "@chakra-ui/react": "2.10.9",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "jest-util": "^29.7.0"
  }
}
